+def _env_method(env, method_name):
+    """Return a custom environment method through Gymnasium wrappers."""
+    if hasattr(env, "get_wrapper_attr"):
+        try:
+            return env.get_wrapper_attr(method_name)
+        except AttributeError:
+            pass
+    return getattr(getattr(env, "unwrapped", env), method_name)
+
+
+def _get_eef_pos(obs):
+    agent_obs = obs.get("agent", {})
+    if isinstance(agent_obs, dict):
+        return agent_obs.get("eef_pos")
+    return None
